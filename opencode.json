{
  "$schema": "https://opencode.ai/config.json",
  "agent": {
    "security-reviewer": {
      "description": "Reviews code for security vulnerabilities and insecure patterns.",
      "mode": "subagent",
      "model": "anthropic/claude-sonnet-4-6",
      "permission": {
        "read": "allow",
        "edit": "deny",
        "bash": "ask"
      }
    }
  }
}
