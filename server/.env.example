# Server Environment Variables
# Copy this file to .env and fill in the values

# Database
DATABASE_URL="postgresql://postgres:password@localhost:5432/ticket_management"

# Server
PORT=3001
NODE_ENV=development

# Session
SESSION_SECRET="your-super-secret-session-key-change-in-production"
SESSION_MAX_AGE=86400000

# Auth
BETTER_AUTH_URL="http://localhost:3001"

# Seed (used by db:seed script)
SEED_ADMIN_EMAIL=admin@example.com
SEED_ADMIN_PASSWORD=password123

# CORS
CLIENT_URL="http://localhost:5173"

# Anthropic (Claude AI)
ANTHROPIC_API_KEY="your-anthropic-api-key"

# Email (SendGrid)
# Outbound: agent replies & AI auto-resolves are sent to the customer via SendGrid
# Inbound: configure SendGrid Inbound Parse to POST to /api/email/inbound
SENDGRID_API_KEY="your-sendgrid-api-key"
EMAIL_FROM="support@yourapp.com"
INBOUND_EMAIL_WEBHOOK_SECRET="your-webhook-secret"

# IMAP Polling (alternative to SendGrid Inbound Parse)
# Set these to have the server poll an inbox and auto-create tickets
IMAP_HOST="imap.example.com"
IMAP_PORT=993
IMAP_USER="support@yourapp.com"
IMAP_PASS="your-imap-password"
IMAP_POLL_INTERVAL=60000

# Sentry (Error Monitoring)
# Create a Node.js project at https://sentry.io to get your DSN
SENTRY_DSN=
SENTRY_ENVIRONMENT=development
